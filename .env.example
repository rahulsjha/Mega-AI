# Database Configuration
DB_USER=mega_ai_user
DB_PASSWORD=secure_password_change_me
DB_NAME=mega_ai
DATABASE_URL=postgresql+asyncpg://mega_ai_user:secure_password_change_me@db:5432/mega_ai

# LLM API Keys
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# RAG Configuration
CHROMA_PATH=./chroma_data
VECTOR_STORE_TYPE=chroma

# Budget Configuration
DEFAULT_CONTEXT_BUDGET_TOKENS=4000
COMPRESSION_THRESHOLD_PERCENT=80

# Orchestrator Configuration
MAX_ORCHESTRATOR_ITERATIONS=10
AGENT_TIMEOUT_SECONDS=30

# Evaluation Configuration
EVAL_DETERMINISTIC_SEED=42
EVAL_TEMPERATURE=0.0
